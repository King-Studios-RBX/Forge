{
	"name": "@kingstudios/forge",
	"version": "0.4.13",
	"description": "An App Manager for Vide",
	"main": "out/init.lua",
	"types": "out/index.d.ts",
	"packageManager": "bun@1.3.14",
	"scripts": {
		"compile": "rbxtsc && node -e \"const fs=require('fs');const f='out/index.d.ts';fs.writeFileSync(f,'/// <reference path=\\\"./types/global.d.ts\\\" />\\n'+fs.readFileSync(f,'utf8'))\""
	},
	"keywords": [
		"roblox-ts",
		"vide"
	],
	"author": "Loner1536",
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/King-Studios-RBX/Forge"
	},
	"bugs": {
		"url": "https://github.com/Loner1536/Forge/issues"
	},
	"files": [
		"out",
		"!**/*.tsbuildinfo",
		"!**/*.spec.lua",
		"!**/*.spec.d.ts"
	],
	"dependencies": {
		"@rbxts/services": "^1.6.0",
		"@rbxts/set-timeout": "^1.1.2",
		"@rbxts/vide": "^0.6.1"
	},
	"devDependencies": {
		"turbo": "^2.9.14",
		"concurrently": "^9.2.1",
		"@rbxts/compiler-types": "^3.0.0-types.0",
		"@biomejs/biome": "^2.4.15",
		"@rbxts/types": "^1.0.920",
		"roblox-ts": "^3.0.0",
		"typescript": "^5.9.3",
		"@types/bun": "^1.3.14"
	}
}